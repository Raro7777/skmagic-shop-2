# skmagic-shop-2 (clone instance) 환경변수 템플릿
#
# Vercel 새 프로젝트 → Settings → Environment Variables 에 아래 값들 입력.
# 색상 ▣ = 원본과 다른 값 (분리 필수)
# 색상 ▢ = 원본과 동일 값 (공유 OK)

# ─────────────── 데이터베이스 (▣ 분리) ───────────────
# Neon 새 계정 → 새 프로젝트 → Connection details
DATABASE_URL=postgresql://USER:PASS@HOST/DB?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASS@HOST/DB?sslmode=require

# ─────────────── NextAuth (▣ 분리) ───────────────
# 새 AUTH_SECRET 발급: `openssl rand -base64 32` 결과 사용
AUTH_SECRET=새_랜덤_32바이트_base64
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://skmagic-shop-2.vercel.app  # 도메인 추가 후 변경

# ─────────────── Vercel Blob (▣ 별도 store) ───────────────
# Vercel Storage → Create → Blob → connect to project → 자동 inject
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_NEW_TOKEN_HERE

# ─────────────── Resend (▢ 공유, FROM 만 분리) ───────────────
RESEND_API_KEY=원본과_동일
RESEND_FROM=Rentking <noreply@skmagic-shop.com>  # 새 도메인 verify 후 변경
EMAIL_PROVIDER=resend

# ─────────────── Telegram (▢ 봇 공유 / ▣ chat 분리) ───────────────
TELEGRAM_BOT_TOKEN=원본과_동일  # 같은 @SKmagicShopBot 사용
TELEGRAM_CHAT_ID_HQ=새_본사_채팅_ID  # 새 텔레그램 채팅방 + 봇 초대 + /start → chat_id

# ─────────────── 기타 (Cron, etc.) ───────────────
# CRON 작업 인증용 (기본 빈 값이면 cron endpoint 비활성)
CRON_SECRET=새_랜덤_시크릿

# ─────────────── 안 쓰는 항목 (현재 instance 와 동일) ───────────────
# 네이버 wcs — Partner.naverWcsId 컬럼 (DB) 으로 관리. env 불필요.
